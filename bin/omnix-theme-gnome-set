#!/usr/bin/env bash

set_kvantum_theme() {
  local theme="$1"
  mkdir -p ~/.config/Kvantum
  if [[ -f ~/.config/Kvantum/kvantum.kvconfig ]] && grep -q '^theme=' ~/.config/Kvantum/kvantum.kvconfig; then
    sed -i "s|^theme=.*|theme=${theme}|" ~/.config/Kvantum/kvantum.kvconfig
  else
    printf '[General]\ntheme=%s\n' "$theme" > ~/.config/Kvantum/kvantum.kvconfig
  fi
}

# Change gnome modes
if [[ -f ~/.config/omnix/current/theme/light.mode ]]; then
  gsettings set org.gnome.desktop.interface color-scheme "prefer-light"
  gsettings set org.gnome.desktop.interface gtk-theme "WhiteSur-Light"
  set_kvantum_theme "WhiteSur-opaque"
else
  gsettings set org.gnome.desktop.interface color-scheme "prefer-dark"
  gsettings set org.gnome.desktop.interface gtk-theme "WhiteSur-Dark"
  set_kvantum_theme "WhiteSur-opaqueDark"
fi

# Change gnome icon theme color
GNOME_ICONS_THEME=~/.config/omnix/current/theme/icons.theme
if [[ -f $GNOME_ICONS_THEME ]]; then
  gsettings set org.gnome.desktop.interface icon-theme "$(<$GNOME_ICONS_THEME)"
else
  gsettings set org.gnome.desktop.interface icon-theme "WhiteSur-red-dark"
fi
