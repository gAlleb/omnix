#!/usr/bin/env bash

export OMNIX_PATH=$HOME/.local/share/omnix
export PATH=$OMNIX_PATH/bin/:$PATH

set -e  

FIRST_RUN_MODE=~/.local/state/omnix/first-run.mode

if [[ -f "$FIRST_RUN_MODE" ]]; then
  rm -f "$FIRST_RUN_MODE"
  sed -i '/^exec-once=omnix-cmd-first-run\s*$/d' ~/.config/mango/conf/autostart.conf
  omnix-font-set "CaskaydiaMono Nerd Font"
  omnix-init-wallpaper
  omnix-theme-set redpeace
  omnix-webapp-install "omFM" https://omfm.ru/ omFM.png
  omnix-webapp-install "WhatsApp" https://web.whatsapp.com/ WhatsApp.png
  omnix-webapp-install "AIstudio" https://aistudio.google.com/ AIstudio.png
  omnix-webapp-install "YouTube" https://youtube.com/ YouTube.png
  omnix-webapp-install "GitHub" https://github.com/ GitHub.png
  omnix-webapp-install "ClaudeAI" https://claude.ai/ ClaudeAI.png
  omnix-tui-install "Disk Usage" "bash -c 'dust -r; read -n 1 -s'" float "Disk Usage.png"
fi
